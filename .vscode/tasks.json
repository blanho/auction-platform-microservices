{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build AuctionService API",
			"type": "shell",
			"command": "dotnet build AuctionService/API/AuctionService.API.csproj",
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build"
		},
		{
			"label": "Run AuctionService API",
			"type": "shell",
			"command": "dotnet run --project AuctionService/API/AuctionService.API.csproj",
			"isBackground": true,
			"group": "test"
		},
		{
			"label": "Build Notification Service",
			"type": "shell",
			"command": "dotnet build src/Services/Notification/Notification.Api/Notification.Api.csproj --nologo 2>&1 | tail -4"
		}
	]
}